# Public Supabase config — pakai anon/publishable key (RLS aktif di backend)
# URL = base API gateway (Kong) yang serve REST + Auth + Realtime.
# Untuk SiMarsel di marsel-base.online, gunakan api.marsel-base.online.

NEXT_PUBLIC_SUPABASE_URL=https://api.marsel-base.online
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
