# ---------------------------------------------------------------------------
# Copy file ini menjadi `.env.local` lalu isi dengan kredensial asli.
# `.env.local` sudah di-gitignore — JANGAN commit file ini dengan nilai asli.
# ---------------------------------------------------------------------------

# =========================================================================
# Frontend (dipakai browser — boleh VITE_ prefix)
# =========================================================================

# Dari Supabase Dashboard → Project Settings → API → "Project URL"
# Contoh: https://abcdefgh.supabase.co
VITE_SUPABASE_URL="https://syebwmtallqqorrcxvjm.supabase.co"

# Dari Supabase Dashboard → Project Settings → API → "anon public"
# Anon key AMAN di-ship ke browser karena dilindungi RLS.
# JANGAN gunakan service_role key di sini.
VITE_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InN5ZWJ3bXRhbGxxcW9ycmN4dmptIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzY4MjIyNjEsImV4cCI6MjA5MjM5ODI2MX0.4ymdramJ4ycazf0BznBlDqJrUiWAwkEjhWDPtpXnLEQ"

# =========================================================================
# Server-side (hanya dipakai di Vercel serverless functions / cron)
# Set di Vercel Dashboard → Settings → Environment Variables.
# =========================================================================

# API key Markaz — dikirim via header Authorization ke cerehub.id
MARKAZ_API_KEY="your-markaz-api-key"

# Base URL Markaz (TANPA "/api" — kode handle path /api/transactions, /api/user-daily otomatis)
MARKAZ_API_BASE_URL="https://markaz.cerehub.id"

# Secret buat verifikasi call dari Vercel Cron (generate random string panjang).
# Vercel otomatis kirim header: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-random-string-32-chars"

# Service role key Supabase (bypass RLS) — hanya dipakai server-side.
# Dari Supabase Dashboard → Project Settings → API → service_role
# JANGAN expose ke browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# User ID yang menerima data dari cron (karena cron gak punya session user).
# Dari Supabase Dashboard → Authentication → Users → klik user → copy UID.
SYNC_TARGET_USER_ID="00000000-0000-0000-0000-000000000000"

# =========================================================================
# Asisten AI (tab "Asisten AI" — analisa, rekomendasi, generate copy)
# =========================================================================

# Anthropic Claude API key — dari https://console.anthropic.com
# Top-up min $5 untuk start (akses ratusan query untuk team kecil).
ANTHROPIC_API_KEY="sk-ant-api03-...your-key-here..."

# Optional: ganti model kalau mau lebih murah (haiku) atau lebih kuat (opus).
# Default: claude-sonnet-4-6 (balance harga + kualitas).
# ANTHROPIC_MODEL="claude-sonnet-4-6"
# ANTHROPIC_MODEL="claude-haiku-4-5-20251001"   # cheapest

# Optional: max output tokens (default 1024)
# ANTHROPIC_MAX_TOKENS="1024"
